<% layout("layouts/boilerplate") %>

    <div class="container mt-4">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="card shadow border-0 rounded-4">

                    <div class="card-header bg-primary text-white">

                        <h3 class="mb-0">
                            <i class="bi bi-pencil-square"></i> Edit Note
                        </h3>

                    </div>

                    <div class="card-body p-4">

                        <form action="/notes/<%= note._id %>?_method=PUT" method="POST" enctype="multipart/form-data">

                            <!-- Title -->

                            <div class="mb-3">

                                <label class="form-label fw-bold">

                                Title

                            </label>

                                <input type="text" name="title" class="form-control" value="<%= note.title %>" required>

                            </div>

                            <!-- Subject -->

                            <div class="mb-3">

                                <label class="form-label fw-bold">

                                Subject

                            </label>

                                <input type="text" name="subject" class="form-control" value="<%= note.subject %>" required>

                            </div>

                            <!-- Description -->

                            <div class="mb-3">

                                <label class="form-label fw-bold">

                                Description

                            </label>

                                <textarea name="description" rows="5" class="form-control" required><%= note.description %></textarea>

                            </div>

                            <!-- Current PDF -->

                            <div class="mb-3">

                                <label class="form-label fw-bold">

                                Current PDF

                            </label>

                                <br>

                                <a href="/<%= note.file %>" target="_blank" class="btn btn-outline-primary btn-sm">

                                    <i class="bi bi-file-earmark-pdf"></i> View Current PDF

                                </a>

                            </div>

                            <!-- Replace PDF -->

                            <div class="mb-4">

                                <label class="form-label fw-bold">

                                Replace PDF (Optional)

                            </label>

                                <input type="file" name="file" class="form-control" accept=".pdf">

                                <small class="text-muted">

                                Leave empty to keep the current PDF.

                            </small>

                            </div>

                            <!-- Buttons -->

                            <div class="d-flex gap-2">

                                <button class="btn btn-success">

                                <i class="bi bi-check-circle"></i>

                                Update Note

                            </button>

                                <a href="/notes/my-notes" class="btn btn-secondary">

                                    <i class="bi bi-arrow-left"></i> Cancel

                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>
