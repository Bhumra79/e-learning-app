<%- layout("layouts/boilerplate") %>

    <div class="container mt-4">

        <h2 class="fw-bold mb-4">My Notes</h2>
        <div class="row  mb-4">

            <div class="col-md-3">
                <div class="card stat-card rounded-4 ">
                    <div class="card-body">
                        <div class="note-icon me-3  ">
                            <i class="bi bi-journal-text fs-1 text-primary"></i>
                        </div>
                        <h6 class="text-primary">Total Notes</h6>
                        <h2>
                            <%= totalNotes %>
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card stat-card rounded-4">
                    <div class="card-body">
                        <div class="note-icon me-3  ">
                            <i class="bi bi-patch-check-fill fs-1 text-success"></i>
                        </div>
                        <h6 class="text-success">Approved</h6>
                        <h2>
                            <%= approvedNotes %>
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card stat-card rounded-4">
                    <div class="card-body ">
                        <div class=" note-icon me-3  ">
                            <i class="bi bi-hourglass-split  fs-1 text-warning"></i>
                        </div>
                        <h6 class="text-warning">Pending</h6>
                        <h2>
                            <%= pendingNotes %>
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card stat-card rounded-4">
                    <div class="card-body">
                        <div class=" note-icon me-3  ">
                            <i class="bi bi-x-circle-fill  fs-1 text-danger"></i>
                        </div>
                        <h6 class="text-danger">Rejected</h6>
                        <h2>
                            <%= rejectedNotes %>
                        </h2>
                    </div>
                </div>
            </div>

        </div>

        <% if(notes.length> 0){ %>

            <div class="table-responsive">
                <table class="table table-bordered">

                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Subject</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% notes.forEach(note=> { %>

                            <tr>

                                <td>
                                    <%= note.title %>
                                </td>

                                <td>
                                    <%= note.subject %>
                                </td>

                                <td>

                                    <% if(note.status==="approved" ){ %>

                                        <span class="badge bg-success">
                                            <i class="bi bi-patch-check-fill"></i>
                                            Approved
                                        </span>

                                        <% } else if(note.status==="pending" ){ %>

                                            <span class="badge bg-warning">
                                                <i class=" bi bi-hourglass-split"></i>
                                                Pending
                                            </span>

                                            <% } else { %>

                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle-fill"></i>
                                                    Rejected
                                                </span>

                                                <% } %>

                                </td>

                                <td>
                                    <%= note.createdAt.toLocaleDateString("en-IN",{
                                        day:"2-digit",
                                        month:"short",
                                        year:"numeric"
                                    }) %>
                                </td>

                                <td>
                                    <!-- View -->
                                    <a href="/notes/my-notes/<%= note._id %>" class="btn btn-sm btn-primary" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <!-- Edit -->
                                    <a href="/notes/<%= note._id %>/edit" class="btn btn-sm btn-warning" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <!-- Delete -->
                                    <form action="/notes/<%= note._id %>?_method=DELETE" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to Delete this note?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                    </form>
                                    <!-- Download -->

                                    <% if(note.status ==="approved"){ %>
                                        <a href="/<%= note.file %>" class="btn btn-sm btn-success" download title="Download"> <i class="bi bi-download"></i>
                                        </a>
                                        <% } %>

                                </td>


                            </tr>

                            <% }) %>

                    </tbody>

                </table>
            </div>
            <% } else { %>
                <div class="card shadow-sm border-0  rounded-4 p-5 text-center">
                    <div class="card-body">

                        <i class="bi bi-journal-bookmark-fill display-1 text-primary"></i>

                        <h3 class="mt-3">No Notes Yet</h3>

                        <p class="text-muted">
                            You haven't uploaded any notes yet. Start sharing your study material with others.
                        </p>

                        <a href="/notes/upload" class="btn btn-primary btn-lg px-4 rounded-pill">
                            <i class="bi bi-cloud-upload"></i> Upload Your First Note
                        </a>

                    </div>
                </div>

                <% } %>

    </div>
