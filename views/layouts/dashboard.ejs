<% layout('layouts/boilerplate') %>

<!-- HERO SECTION -->
<section class="hero-section text-center py-5">

    <div class="container py-5">

        <h1 class="display-4 fw-bold ">
            Learn, Share & Grow 📘
        </h1>

        <p class="lead text-muted mt-3">
            Upload notes, explore study material,
            and learn through videos.
        </p>

        <!-- Buttons -->
        <div class="mt-4">

            <a href="/register"
            class="btn btn-primary btn-lg me-2">

                Get Started
            </a>

            <a href="/notes"
            class="btn btn-outline-dark btn-lg">

                Explore Notes
            </a>

        </div>

    </div>

</section>

<!-- SEARCH SECTION -->
<section class="container mb-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow-sm border-0 p-4 rounded-4">

                <h4 class="mb-3 text-center">
                    Search Study Material
                </h4>

                <form  action="/notes" method="GET" class="d-flex">

                    <input
                    type="text"
                    name="search"
                    class="form-control me-2"
                    placeholder="Search notes by title, subject..."
                    value="<%=  typeof search !== 'undefined' ? search : '' %>">


                    <button class="btn btn-dark">
                        Search
                    </button>

                </form>

            </div>

        </div>

    </div>

</section>

<!-- FEATURES -->
<section class="container mb-5">

    <h2 class="text-center mb-4 fw-bold">
        Features
    </h2>

    <div class="row g-4">

        <!-- Card 1 -->
        <div class="col-md-4">

            <div class="card h-100 shadow-sm border-0 rounded-4 p-3">

                <div class="card-body text-center">

                    <h1>📄</h1>

                    <h4 class="mt-3">
                        Upload Notes
                    </h4>

                    <p class="text-muted">
                        Share your study notes with classmates easily.
                    </p>

                </div>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="col-md-4">

            <div class="card h-100 shadow-sm border-0 rounded-4 p-3">

                <div class="card-body text-center">

                    <h1>🎥</h1>

                    <h4 class="mt-3">
                        Video Learning
                    </h4>

                    <p class="text-muted">
                        Learn through curated YouTube videos.
                    </p>

                </div>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="col-md-4">

            <div class="card h-100 shadow-sm border-0 rounded-4 p-3">

                <div class="card-body text-center">

                    <h1>📚</h1>

                    <h4 class="mt-3">
                        Subject Wise Notes
                    </h4>

                    <p class="text-muted">
                        Find organized notes by subject and topic.
                    </p>

                </div>
            </div>
        </div>

    </div>

</section>

<!-- SUBJECTS SECTION -->
<section class="container mb-5 subjects-section">

    <h2 class="text-center mb-4 fw-bold">
        Popular Subjects
    </h2>

    <div class="row g-4">

        <div class="col-md-3">
            <div class="subject-card">Web Development</div>
        </div>

        <div class="col-md-3">
            <div class="subject-card">Java Programming</div>
        </div>

        <div class="col-md-3">
            <div class="subject-card">DBMS</div>
        </div>

        <div class="col-md-3">
            <div class="subject-card">Operating System</div>
        </div>

    </div>

</section>

<!-- VIDEO SECTION -->
<section class="container mb-5">

    <h2 class="text-center mb-4 fw-bold">
        Featured Learning Videos
    </h2>

    <div class="row g-4">

        <!-- Video 1 -->
        <div class="col-md-6">

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

                <iframe
                width="100%"
                height="315"
                src="https://www.youtube.com/embed/ZxKM3DCV2kE"
                title="YouTube video"
                allowfullscreen>
                </iframe>

            </div>

        </div>

        <!-- Video 2 -->
        <div class="col-md-6">

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

                <iframe
                width="100%"
                height="315"
                src="https://www.youtube.com/embed/BLl32FvcdVM"
                title="YouTube video"
                allowfullscreen>
                </iframe>

            </div>

        </div>

    </div>

</section>
