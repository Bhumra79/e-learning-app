<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LearnHub Admin Panel</title>

    <link href="/css/style.css" rel="stylesheet" />
    <link href="/css/admin.css" rel="stylesheet" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body>
    <div class="container-fluid">
      <div class="row">
        <!-- Sidebar -->
        <div class="col-md-2 sidebar p-0">
          <div class="p-3">
            <h3 class="text-white fw-bold">📘 LearnHub</h3>

            <hr class="text-secondary" />

            <ul class="nav flex-column">
              <li class="nav-item mb-2">
                <a
                  href="/admin/dashboard"
                  class="nav-link text-white <%= currentPage === 'dashboard' ? 'active' : '' %>"
                >
                  <i class="bi bi-speedometer2"></i> Dashboard
                </a>
              </li>

              <li class="nav-item mb-2">
                <a
                  href="/admin/users"
                  class="nav-link text-white <%= currentPage === 'users' ? 'active' : '' %>"
                >
                  <i class="bi bi-people"></i> Manage Users
                </a>
              </li>

              <li class="nav-item mb-2">
                <a
                  href="/admin/notes"
                  class="nav-link text-white <%= currentPage === 'notes' ? 'active' : '' %>"
                >
                  <i class="bi bi-journal-text"></i> Manage Notes
                </a>
              </li>

              <li class="nav-item mb-2">
                <a
                  href="/admin/notes/pending"
                  class="nav-link text-white <%= currentPage === 'pending' ? 'active' : '' %>"
                >
                  <i class="bi bi-clock-history"></i> Pending Notes
                </a>
              </li>

              <li class="nav-item mb-2">
                <a
                  href="/admin/notes/approved"
                  class="nav-link text-white <%= currentPage === 'approved' ? 'active' : '' %>"
                >
                  <i class="bi bi-check-circle"></i>Approved Notes
                </a>
              </li>
              
              <li class="nav-item mb-2">
                <a
                  href="/admin/notes/rejected"
                  class="nav-link text-white <%= currentPage === 'rejected' ? 'active' : '' %>"
                >
                  <i class="bi bi-x-circle"></i>Rejected Notes
                </a>
              </li>

              <li class="nav-item mb-2">
                <a href="/" class="nav-link text-white">
                  <i class="bi bi-house"></i> Home
                </a>
              </li>

              <li class="nav-item mt-4">
                <a href="/logout" class="nav-link text-danger">
                  <i class="bi bi-box-arrow-right"></i> Logout
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-10">
          <div class="p-4">
            <%- include("../includes/flash.ejs") %> <%- body %>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/adminChart.js"></script>
    <script src="/js/script.js"></script>
    <script src="/js/theme.js"></script>
  </body>
</html>
