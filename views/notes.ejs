<% layout('layouts/boilerplate') %>

    <div class="container mt-5">
        <!-- ================= HERO SECTION ================= -->

        <section class="browse-hero">

            <div class="hero-bg-circle hero-circle-1"></div>
            <div class="hero-bg-circle hero-circle-2"></div>

            <div class="container">

                <div class="row align-items-center">

                    <!-- Left Image -->

                    <div class="col-lg-3 text-center d-none d-lg-block">

                        <!-- <img src="/images/book.png" class="hero-book" alt="Books"> -->
                        <i class=" bi  bi-book-half hero-icon"></i>

                    </div>

                    <!-- Center -->

                    <div class="col-lg-6 text-center">

                        <h1 class="hero-title">

                            Browse Study Notes 📚

                        </h1>

                        <p class="hero-subtitle">

                            Explore high quality study materials shared by LearnHub users.
                            <br> Find notes for every subject and topic.

                        </p>

                        <a href="/notes/upload" class="btn hero-upload-btn">

                            <i class="bi bi-upload me-2"></i> Upload New Notes

                        </a>

                    </div>

                    <!-- Right Image -->

                    <div class="col-lg-3 text-center d-none d-lg-block">

                        <!-- <img src="/images/folder.png" class="hero-folder" alt="Folder"> -->
                        <i class="bi bi-folder2-open hero-icon"></i>
                    </div>

                </div>

            </div>

        </section>
        <!-- ================= SEARCH ================= -->

        <div class="card border-0 shadow-sm rounded-4 mb-2">

            <div class="card-body">

                <form action="/notes" method="GET">

                    <div class="row g-3">

                        <div class="col-lg-5">

                            <label class="fw-semibold mb-2">
                                Search Notes
                            </label>

                            <div class="input-group">

                                <span class="input-group-text bg-white">

                                    <i class="bi bi-search"></i>

                                </span>

                                <input type="text" name="search" class="form-control" placeholder="Search by title, subject or description...">

                            </div>

                        </div>

                        <div class="col-lg-3">

                            <label class="fw-semibold mb-2">
                                Subject
                            </label>

                            <select class="form-select" name="subject">

                                <option value="">All Subjects</option>
                                <option>Java</option>
                                <option>Python</option>
                                <option>DBMS</option>
                                <option>Operating System</option>
                                <option>Computer Networks</option>
                                <option>Data Structures</option>

                            </select>

                        </div>

                        <div class="col-lg-2">

                            <label class="fw-semibold mb-2">
                                Sort By
                            </label>

                            <select class="form-select" name="sort">

                                <option value="newest">Newest First</option>
                                <option value="oldest">Oldest First</option>

                            </select>

                        </div>

                        <div class="col-lg-2 d-grid">

                            <label class="invisible">
                                Search
                            </label>

                            <button class="btn btn-primary">

                                <i class="bi bi-search me-2"></i>

                                Search

                            </button>

                        </div>

                    </div>

                </form>

            </div>

        </div>

        <!-- ================= STATISTICS ================= -->

        <div class="row g-4 mb-5">

            <!-- Total Notes -->

            <div class="col-lg-3 col-md-6">

                <div class="card stats-card border-0 shadow-sm  h-0">

                    <div class="card-body d-flex align-items-center py-3 px-3">

                        <div class="stat-icon bg-primary-subtle text-primary">

                            <i class="bi bi-journal-bookmark-fill"></i>

                        </div>

                        <div class="ms-3">

                            <h2 class="fw-bold mb-0">

                                <%= notes.length %>

                            </h2>

                            <small class="text-muted">

                                Total Notes

                            </small>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Approved -->

            <div class="col-lg-3 col-md-6">

                <div class="card  stats-card border-0 shadow-sm  h-0">

                    <div class="card-body d-flex align-items-center" py-3 px-3>

                        <div class="stat-icon bg-success-subtle text-success">

                            <i class="bi bi-check-circle-fill"></i>

                        </div>

                        <div class="ms-3">

                            <h2 class="fw-bold mb-0">

                                <%= notes.filter(note=>note.status==="approved").length %>

                            </h2>

                            <small class="text-muted">

                                Approved Notes

                            </small>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Contributors -->

            <div class="col-lg-3 col-md-6">

                <div class="card stats-card border-0 shadow-sm  h-0">

                    <div class="card-body d-flex align-items-center py-3 px-3">

                        <div class="stat-icon bg-warning-subtle text-warning">

                            <i class="bi bi-people-fill"></i>

                        </div>

                        <div class="ms-3">

                            <h2 class="fw-bold mb-0">

                                <%= new Set(notes.map(note=>note.owner?._id?.toString())).size %>

                            </h2>

                            <small class="text-muted">

                                Contributors

                            </small>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Subjects -->

            <div class="col-lg-3 col-md-6">

                <div class="card stats-card border-0 shadow-sm  h-0">

                    <div class="card-body d-flex align-items-center py-3 px-3">

                        <div class="stat-icon bg-info-subtle text-info">

                            <i class="bi bi-grid-fill"></i>

                        </div>

                        <div class="ms-3">

                            <h2 class="fw-bold mb-0">

                                <%= new Set(notes.map(note=>note.subject)).size %>

                            </h2>

                            <small class="text-muted">

                                Subjects

                            </small>

                        </div>

                    </div>

                </div>

            </div>

        </div>



        <!-- ================= BROWSE NOTES ================= -->

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h2 class="fw-bold mb-1">
                    Browse Notes
                </h2>

                <p class="text-muted mb-0">
                    Discover high-quality study resources.
                </p>

            </div>

            <span class="badge bg-primary px-3 py-2 fs-6 rounded-pill">

                <%= notes.length %> Notes Found

            </span>

        </div>

        <div class="row g-4">

            <% if(notes.length===0){ %>

                <div class="col-12">

                    <div class="card border-0 shadow-sm rounded-4 text-center p-5">

                        <i class="bi bi-journal-x display-1 text-secondary"></i>

                        <h3 class="mt-3">

                            No Notes Found

                        </h3>

                        <p class="text-muted">

                            Try another search.

                        </p>

                    </div>

                </div>

                <% } %>

                    <% notes.forEach(note=>{ %>

                        <div class="col-xl-3 col-lg-4 col-md-0 mb-4">

                            <div class="card note-card h-100 border-0 shadow-sm rounded-4">

                                <!-- PDF -->

                                <div class="text-center pt-4">

                                    <img src="/images/pdf.png" class="pdf-image">

                                </div>

                                <div class="card-body">

                                    <h5 class="fw-bold">

                                        <%= note.title %>

                                    </h5>

                                    <span class="badge bg-primary rounded-pill">

                                        <%= note.subject %>

                                    </span>

                                    <p class="text-muted mt-3">

                                        <%= note.description.length> 90
                                            ? note.description.substring(0,90) + "..."
                                            : note.description %>

                                    </p>

                                    <hr>

                                    <div class="d-flex justify-content-between align-items-center mb-3">

                                        <small class="text-muted">

                                            <i class="bi bi-person-circle me-1"></i>

                                            <%= note.owner ? note.owner.username : "Unknown" %>

                                        </small>

                                        <small class="text-muted">

                                            <i class="bi bi-calendar3 me-1"></i>

                                            <%= new Date(note.createdAt).toLocaleDateString() %>

                                        </small>

                                    </div>

                                    <% if(note.status==="approved" ){ %>

                                        <span class="badge bg-success rounded-pill">

                                            Approved

                                        </span>

                                        <% } else { %>

                                            <span class="badge bg-warning text-dark rounded-pill">

                                                Pending

                                            </span>

                                            <% } %>

                                </div>

                                <div class="card-footer bg-white border-0">

                                    <div class="d-grid gap-2">

                                        <a href="/notes/<%= note._id %>" class="btn btn-outline-primary rounded-pill">

                                            <i class="bi bi-eye me-2"></i> View Details

                                        </a>

                                        <% if(note.status==="approved" ){ %>

                                            <a href="/<%= note.file %>" download class="btn btn-primary rounded-pill">

                                                <i class="bi bi-download me-2"></i> Download PDF

                                            </a>

                                            <% } %>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <% }) %>

        </div>
        <!-- Pagination -->

        <% if(totalPages> 1){ %>

            <nav class="mt-5 mb-2 d-flex justify-content-center">

                <ul class="pagination ">

                    <% if(currentPage> 1){ %>

                        <li class="page-item">

                            <a class="page-link" href="/notes?page=<%= currentPage-1 %> &search=<%= search || '' %>&subject=<%= subject || '' %>&sort=<%= sort || 'newest' %> ">

                                Previous

                            </a>

                        </li>

                        <% } %>

                            <% for(let i=1;i<=totalPages;i++){ %>

                                <li class="page-item <%= currentPage===i ? 'active' : '' %>">

                                    <a class="page-link" href="/notes?page=<%= i %>&search=<%= search || '' %>&subject=<%= subject || '' %>&sort=<%= sort || 'newest' %> ">

                                        <%= i %>

                                    </a>

                                </li>

                                <% } %>

                                    <% if(currentPage < totalPages){ %>

                                        <li class="page-item">

                                            <a class="page-link" href="/notes?page=<%= currentPage+1 %>&search=<%= search %> &subject=<%= subject || '' %>&sort=<%= sort || 'newest' %> ">

                                                Next

                                            </a>

                                        </li>

                                        <% } %>

                </ul>

            </nav>

            <% } %>




    </div>
