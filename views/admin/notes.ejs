<%- layout("layouts/admin") %>
    <div class="container mt-4">

        <h2 class="fw-bold"><i class="bi bi-journal-text  text-primary"></i> Manage Notes </h2>
        <div class="row mb-4">

            <div class="col-md-3">
                <div class="card stat-card notes ">
                    <div class="card-body ">
                        <div class="note-icon1 note-icon me-3">
                            <i class="bi bi-file-earmark-text-fill fs-1 text-success"></i>
                        </div>
                        <h5>
                            Total Notes
                        </h5>
                        <h2>
                            <%= notes.length %>
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card  stat-card">
                    <div class="card-body">
                        <div class="note-icon3 note-icon me-3">
                            <i class="bi bi-book-half fs-3"></i>
                        </div>
                        <h5>
                            Subjects
                        </h5>
                        <h2>
                            <%= subjectsCount %>
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card   stat-card ">
                    <div class="card-body">
                        <div class="note-icon me-3">
                            <i class="bi bi-people-fill fs-3"></i>
                        </div>
                        <h5>
                            Active Uploaders
                        </h5>
                        <h2>
                            <%= new Set(notes.map(n=>n.owner?._id)).size %>
                        </h2>
                    </div>
                </div>
            </div>
        </div>


        <div class="card shadow border-0">
            <div class="card-body">
                <div class="table-responsive">

                    <!-- search box -->
                    <div class="input-group mb-3">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="noteSearch" class="form-control"
                            placeholder="Search notes by title, subject, uploader">
                    </div>
                    <div id="noResults" class="text-center text-muted mt-4 d-none"> </div>

                    <% if(notes.length===0){ %>

                        <div class="card shadow-sm border-0 mt-4">
                            <div class="card-body text-center py-5">

                                <i class="bi bi-folder-x display-1 text-primary"></i>

                                <h3 class="mt-3">No Notes Found</h3>

                                <p class="text-muted">
                                    There are currently no notes in the system.
                                </p>

                                <span class="badge bg-light text-dark">
                                    Waiting for uploads...
                                </span>

                            </div>
                        </div>

                        <% } else { %>

                            <!-- Notes Table -->
                            <table class="table-responsive table table-striped table-hover shadow-sm border-0">
                                <thead class="table-light">
                                    <tr>

                                        <th>Title</th>
                                        <th>Subject</th>
                                        <th>Uploaded By</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                        <th>Action</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    <% notes.forEach(note=> { %>
                                        <tr class="note-row">
                                            <td>
                                                <%= note.title %>
                                            </td>
                                            <td>
                                                <%= note.subject %>

                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">

                                                    <div class="avatar-circle me-2">
                                                        <%= note.owner?.username?.charAt(0).toUpperCase() || "U" %>
                                                    </div>

                                                    <div>
                                                        <div>
                                                            <%= note.owner?.username || "Unknown" %>
                                                        </div>
                                                        <small class="text-muted">
                                                            <%= note.owner?.email || "No Email" %>
                                                        </small>
                                                    </div>

                                                </div>
                                            </td>

                                            <td>
                                                <% if(note.status==="pending" ){ %>
                                                    <span class="badge bg-warning text-dark">Pending</span>

                                                    <% } else if(note.status==="approved" ){ %>
                                                        <span class="badge bg-success">Approved</span>

                                                        <% } else { %>
                                                            <span class="badge bg-danger">Rejected</span>
                                                            <% } %>
                                            </td>

                                            <td>
                                                <%= note.createdAt.toDateString() %>
                                            </td>
                                            <td>
                                                <a href="/<%= note.file %>" target="_blank"
                                                    class="btn btn-primary btn-sm"> <i class="bi bi-eye"></i></a>
                                                <a href="/<%= note.file %>" download class="btn btn-success btn-sm"><i
                                                        class="bi bi-download"> </i> </a>

                                                <form action="/admin/notes/<%= note._id %>?_method=DELETE" method="POST"
                                                    class="d-inline">
                                                    <button class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Are you sure you want to delete this note?')">
                                                        <i class=" bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>

                                        <% }) %>

                                </tbody>
                            </table>
                            <% } %>
                </div>
            </div>
        </div>
    </div>
