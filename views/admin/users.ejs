<%- layout("layouts/admin") %>
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="fw-bold">
                    <i class="bi bi-people-fill text-primary"></i> Manage Users
                </h2>

                <p class="text-muted mb-0">
                    View and manage all registered users
                </p>
            </div>

            <div>
                <span class="badge bg-primary fs-6">
                                        Total Users : <%= users.length %>
                                      </span>
            </div>

        </div>

        <div class="card shadow border-0">
            <div class="card-body">
                <div class="table-responsive">

                    <div class="input-group mb-4">
                        <span class="input-group-text ">
                        <i class="bi bi-search"></i>
                    </span>
                        <input type="text" id="userSearch" class="form-control" placeholder="Search users by name or email">
                    </div>
                    <div id="noResults" class="text-center text-muted mt-4 d-none"> </div>

                    <table class="table-responsive table table-striped table-hover shadow-sm border-0 ">

                        <thead class="table-light ">

                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Joined</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>

                        </thead>



                        <tbody>

                            <% if(users.length === 0){ %>

                                <tr>
                                    <td colspan="6" class="text-center py-5">

                                        <i class="bi bi-person-x-fill text-primary" style="font-size:70px;"></i>

                                        <h4 class="mt-3 fw-bold">No Users Available</h4>

                                        <p class="text-muted">
                                            Users will appear here after registration.
                                        </p>

                                    </td>
                                </tr>

                                <% } else { %>

                                    <% users.forEach(user => { %>

                                        <!-- Existing User Row -->

                                        <% }) %>

                                            <% } %>


                                                <% users.forEach(user => { %>

                                                    <tr class="user-row">

                                                        <td>
                                                            <div class=" d-flex align-items-center ">
                                                                <div class="avatar-circle me-3 ">
                                                                    <%= user.username.charAt(0).toUpperCase() %>
                                                                </div>
                                                                <div>
                                                                    <%= user.username %>
                                                                </div>
                                                            </div>
                                                        </td>

                                                        <td>
                                                            <%= user.email %>
                                                        </td>


                                                        <td>

                                                            <% if(user.role === "admin "){ %>

                                                                <span class="badge rounded-pill bg-success">
                                    <i class="bi bi-shield-check"></i>
                                           Admin
                                           </span>

                                                                <% } else { %>

                                                                    <span class="badge  rounded-pill bg-primary">
                                        <i class="bi bi-person"></i>
                                    User
                                </span>

                                                                    <% } %>
                                                        </td>

                                                        <td>
                                                            <%= user.createdAt 
                            ? new Date(user.createdAt).toLocaleDateString() : "N/A" %>
                                                        </td>


                                                        <td>
                                                            <% if(user.isOnline){ %>

                                                                <span class="text-success ">
                                            Online
                                        </span>

                                                                <% } else { %>

                                                                    <span class="text-secondary ">
                                    Offline
                                </span>
                                                                    <% } %>
                                                        </td>
                                                        <td>
                                                            <% if(user.role==="user"){ %>

                                                                <form action="/admin/users/<%= user._id %>/make-admin" method="POST" class="d-inline">

                                                                    <button class="btn btn-success btn-sm" title="Make Admin">
                                    <i class=" bi bi-person-up "></i>           
                                </button>

                                                                </form>

                                                                <% } else { %>

                                                                    <form action="/admin/users/<%= user._id %>/remove-admin" method="POST" class="d-inline">

                                                                        <button class="btn btn-warning btn-sm" title="Remove Admin">
                                    <i class="bi bi-person-dash"></i>           
                                </button>

                                                                    </form>

                                                                    <% } %>
                                                                        <form action="/admin/users/<%= user._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?')">

                                                                            <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal <%= user._id %>" title="Delete User">
                                     <i class="bi bi-trash"></i>           
                                </button>

                                                                        </form>


                                                        </td>



                                                    </tr>


                                                    <% }) %>

                        </tbody>

                    </table>


                </div>
            </div>
        </div>
    </div>
