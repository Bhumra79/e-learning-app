<%- layout("layouts/admin") %>

    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">
                <i class="bi bi-x-circle-fill "></i> Rejected Notes
            </h2>
        </div>


        <div class="card shadow border-0">
            <div class="card-body">
                <div class="table-responsive">

                    <!-- search box -->
                    <div class="input-group mb-3">
                        <span class="input-group-text">
                        <i class="bi bi-search"></i>
                    </span>
                        <input type="text" id="noteSearch" class="form-control" placeholder="Search notes by title, subject, uploader">
                    </div>
                    <div id="noResults" class="text-center text-muted mt-4 d-none"> </div>


                    <% if(notes.length === 0){ %>

                        <div class="card shadow-sm border-0">
                            <div class="card-body text-center py-5">
                                <div class="mb-3">
                                     <i class="bi bi-emoji-smile display-1 text-success"></i>
                                    </div>
                                
                                <h4 class="mt-3 fw-bold">No  Rejected Notes</h4>
                                <p class="text-muted mb-0">
                                    Great ! There are currently no rejected notes.
                                </p>
                                <a href="/admin/dashboard" class="btn btn-primary mt-2">
                                 <i class="bi bi-house-door"></i>
                                 Back to Dashboard
                                </a>
                            </div>
                        </div>

                        <% } else { %>
                            <!-- Notes Table -->
                            <table class="table-responsive table table-striped table-hover shadow-sm border-0">
                                <thead class="table-light">
                                    <tr>

                                        <th>Title</th>
                                        <th>Subject</th>
                                        <th>Uploaded By</th>
                                        <th>Uploaded On </th>
                                        <th>Action</th>

                                    </tr>
                                </thead>
                                <tbody>

                                    <% notes.forEach(note=> { %>
                                        <tr class="note-row">
                                            <td>
                                                <%= note.title %>
                                                 <span class="badge bg-danger mb-3">
                                                    Rejected
                                                 </span>
                                            </td>

                                            <td>
                                                <%= note.subject %>

                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">

                                                    <div class="avatar-circle me-2">
                                                        <%= note.owner?.username?.charAt(0).toUpperCase() || "U" %>
                                                    </div>

                                                    <div>
                                                        <div>
                                                            <%= note.owner?.username || "Unknown" %>
                                                        </div>
                                                        <small class="text-muted">
                                                            <%= note.owner?.email || "No Email" %>
                                                            </small>
                                                    </div>

                                                </div>
                                            </td>

                                            <td>
                                                <%= note.createdAt.toDateString() %>
                                            </td>
                                            <td>
                                                <a href="/admin/notes/<%= note._id %>" class="btn btn-primary btn-sm"> <i class="bi bi-eye"></i></a>

                                                <form action="/admin/notes/<%= note._id %>?_method=DELETE" method="POST" class="d-inline">
                                                    <button class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this note?')">
                                            <i class=" bi bi-trash"></i> 
                                        </button>
                                                </form>
                                            </td>
                                        </tr>

                                        <% }) %>

                                </tbody>
                            </table>
                            <% } %>

                </div>
            </div>
        </div>
    </div>
