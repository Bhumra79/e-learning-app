<%- layout("layouts/boilerplate") %>

    <div class="container mt-4">

        <a href="/notes/my-notes" class="btn btn-outline-secondary mb-4">
            <i class="bi bi-arrow-left"></i> Back to My Notes</a>


        <div class="row align-items-start">

            <!-- Left Side -->
            <div class="col-lg-4 mb-4">
                <div class="card shadow rounded-4 sticky-top" style="top:90px;">
                    <div class="card-body">

                        <h2 class="fw-bold text-primary mb-3">
                            <%= note.title %>
                        </h2>

                        <% if(note.status==="approved"){ %>
                            <span class="badge bg-success fs-6">Approved</span>
                            <% } else if(note.status==="pending"){ %>
                                <span class="badge bg-warning text-dark fs-6">Pending</span>
                                <% } else { %>
                                    <span class="badge bg-danger fs-6">Rejected</span>
                                    <% } %>

                                        <hr>

                                        <h5>
                                            <i class="bi bi-book-fill text-primary"></i> Subject
                                        </h5>

                                        <p>
                                            <%= note.subject %>
                                        </p>

                                        <h5>
                                            <i class="bi bi-card-text text-primary"></i> Description
                                        </h5>

                                        <p>
                                            <%= note.description %>
                                        </p>

                                        <h5>
                                            <i class="bi bi-calendar-event text-primary"></i> Uploaded On
                                        </h5>

                                        <p>
                                            <%= note.createdAt.toDateString() %>
                                        </p>
                                        <h5>
                                            <i class="bi bi-person-circle text-primary"></i> Uploaded By
                                        </h5>
                                        <p>
                                            <%= note.owner.username %>
                                        </p>


                                        <% if(note.status==="approved"){ %>

                                            <a href="/<%= note.file %>" class="btn btn-success mt-3" download>

                                                <i class="bi bi-download"></i> Download PDF

                                            </a>

                                            <% } %>


                    </div>
                </div>
            </div>
            <!--Right Side-->
            <div class="col-lg-8">

                <div class="card shadow rounded-4 ">

                    <div class="card-header bg-primary text-white fw-bold">

                        <h5 class="mb-0">
                            <i class="bi bi-file-earmark-pdf-fill"></i> PDF Preview
                        </h5>

                    </div>

                    <div class="card-body p-0">

                        <% if(note.status==="approved"){ %>

                            <iframe src="/<%= note.file %>" width="100%" height="900" style="border:none;">
                    </iframe>

                            <% } else { %>

                                <div class="text-center p-5">

                                    <i class="bi bi-file-earmark-lock display-1 text-secondary"></i>

                                    <h4 class="mt-3">

                                        PDF Preview Not Available

                                    </h4>

                                    <p class="text-muted">

                                        Only approved notes can be previewed.

                                    </p>

                                </div>

                                <% } %>

                    </div>

                </div>

            </div>

        </div>

    </div>
